    "stabilityTiers": {
      "stable": {
        "description": "Fields and request parameters that agents may depend on for routine automation.",
        "changePolicy": "backward-compatible additive changes only; removal, rename, or semantic narrowing requires deprecation."
      },
      "experimental": {
        "description": "Fields that are useful but still allowed to change while the feature matures.",
        "changePolicy": "additive changes are preferred; breaking changes must keep stable fields intact and update contract tests."
      },
      "internal": {
        "description": "Diagnostics or implementation details for local debugging only.",
        "changePolicy": "may change without compatibility guarantees and must not be required by worker prompts."
      },
      "deprecated": {
        "description": "Fields retained for compatibility but no longer recommended.",
        "changePolicy": "may be removed only after the deprecation policy is satisfied."
      }
    },
    "deprecationPolicy": {
      "minimumNoticeDays": 14,
