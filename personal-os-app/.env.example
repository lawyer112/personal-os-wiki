POSTGRES_PASSWORD="replace-with-a-long-random-database-password"
DATABASE_URL="postgresql://personal_os:replace-with-a-long-random-database-password@localhost:54329/personal_os?schema=public"
PERSONAL_OS_API_TOKEN="replace-with-a-long-random-token"
PERSONAL_OS_READ_TOKEN="replace-with-a-long-random-read-token"
WIKI_READ_TOKEN="replace-with-your-personal-wiki-read-token"
WIKI_API_TOKEN="replace-with-your-personal-wiki-token"
PERSONAL_OS_VAULT_DIR="./data/vault"
PERSONAL_OS_ATTACHMENT_DIR="./data/attachments"
# Local development URL. For docker-compose.prod.yml, use .env.prod.example.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WIKI_URL="http://localhost:3422"

# Optional local hybrid recall leg for /api/agent/context.
AGENT_CONTEXT_AGENTMEMORY_ENABLED="false"
AGENT_CONTEXT_AGENTMEMORY_URL="http://localhost:3111"
AGENT_CONTEXT_AGENTMEMORY_LIMIT="5"
AGENT_CONTEXT_AGENTMEMORY_TIMEOUT_MS="1500"
